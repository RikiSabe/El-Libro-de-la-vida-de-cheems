#include <bits/stdc++.h>
using namespace std;

const int MAXN = 200005;

long long arr[MAXN];

struct Node {
    long long st;
    long long lazy;
    bool pending;
};

Node ST[4*MAXN];

void build(int node, int l, int r) {
    ST[node].lazy = 0;
    ST[node].pending = false;
    if (l == r) {
        ST[node].st = arr[l];
        return;
    }
    int mid = (l + r) >> 1;
    build(node<<1, l, mid);
    build(node<<1|1, mid+1, r);
    ST[node].st = min(ST[node<<1].st, ST[node<<1|1].st);
}

void push(int node, int l, int r) {
    if (!ST[node].pending) return;
    ST[node].st = ST[node].lazy;
    if (l != r) {
        ST[node<<1].pending = ST[node<<1|1].pending = true;
        ST[node<<1].lazy = ST[node<<1|1].lazy = ST[node].lazy;
    }
    ST[node].pending = false;
}

void update(int node, int l, int r, int ql, int qr, long long val) {
    push(node, l, r);
    if (qr < l || r < ql) return;
    if (ql <= l && r <= qr) {
        ST[node].pending = true;
        ST[node].lazy = val;
        push(node, l, r);
        return;
    }
    int mid = (l + r) >> 1;
    update(node<<1, l, mid, ql, qr, val);
    update(node<<1|1, mid+1, r, ql, qr, val);
    ST[node].st = min(ST[node<<1].st, ST[node<<1|1].st);
}

long long query(int node, int l, int r, int ql, int qr) {
    push(node, l, r);
    if (qr < l || r < ql) return LLONG_MAX;
    if (ql <= l && r <= qr) return ST[node].st;
    int mid = (l + r) >> 1;
    return min(
        query(node<<1, l, mid, ql, qr),
        query(node<<1|1, mid+1, r, ql, qr)
    );
}

